<script>
(function() {
  const video      = document.getElementById('video-src');
  const canvasR    = document.getElementById('canvas-real');
  const canvasM    = document.getElementById('canvas-mirror');
  const ctxR       = canvasR.getContext('2d');
  const ctxM       = canvasM.getContext('2d');
  const btnStart   = document.getElementById('btn-start');
  const btnFlip    = document.getElementById('btn-flip');
  const startScr   = document.getElementById('start-screen');
  const errorMsg   = document.getElementById('error-msg');
  const errorText  = document.getElementById('error-text');
  const liveDot    = document.getElementById('live-dot');
  const liveText   = document.getElementById('live-text');
  const slider     = document.getElementById('opacity-slider');
  const sliderFill = document.getElementById('slider-fill');
  const opacValue  = document.getElementById('opacity-value');
  const opacMeter  = document.getElementById('opacity-meter');
  const panelReal  = document.getElementById('panel-real');
  const panelMirror= document.getElementById('panel-mirror');

  let facingMode   = 'user';
  let stream       = null;
  let animFrame    = null;
  let ghostOpacity = 0.5;
  let running      = false;
  let w = 0, h = 0;

  // ── Slider logic ──
  function updateSlider(val) {
    const pct = val;
    ghostOpacity = pct / 100;
    opacValue.textContent = pct + '%';

    // Fill
    sliderFill.style.width = pct + '%';

    // Meter bars (5 bars, each = 20%)
    const bars = opacMeter.querySelectorAll('.opacity-bar');
    bars.forEach((b, i) => {
      b.classList.toggle('on', pct > i * 20);
    });
  }

  slider.addEventListener('input', () => updateSlider(parseInt(slider.value)));
  updateSlider(50);

  // ── Resize canvases to panel size ──
  function resizeCanvases() {
    const rw = panelReal.clientWidth;
    const rh = panelReal.clientHeight;
    [canvasR, canvasM].forEach(c => {
      c.width  = rw;
      c.height = rh;
    });
    w = rw;
    h = rh;
  }

  const ro = new ResizeObserver(resizeCanvases);
  ro.observe(panelReal);

  // ── Draw loop ──
  function drawFrame() {
    if (!running) return;
    if (video.readyState < 2) { animFrame = requestAnimationFrame(drawFrame); return; }

    const vw = video.videoWidth  || 1;
    const vh = video.videoHeight || 1;

    // Cover-fit: fill panel, center crop
    const scaleW = w / vw;
    const scaleH = h / vh;
    const scale  = Math.max(scaleW, scaleH);
    const dw     = vw * scale;
    const dh     = vh * scale;
    const dx     = (w - dw) / 2;
    const dy     = (h - dh) / 2;

    // ── LEFT panel: show LEFT half of video ──
    ctxR.clearRect(0, 0, w, h);
    ctxR.drawImage(video, dx, dy, dw, dh);

    // ── RIGHT panel: show LEFT half of video, mirrored ──
    ctxM.clearRect(0, 0, w, h);

    // Draw real image at reduced opacity
    ctxM.globalAlpha = 1 - ghostOpacity;
    ctxM.drawImage(video, dx, dy, dw, dh);

    // Draw mirrored image (ghost) on top
    ctxM.save();
    ctxM.globalAlpha = ghostOpacity;
    ctxM.translate(w, 0);
    ctxM.scale(-1, 1);
    ctxM.drawImage(video, dx, dy, dw, dh);
    ctxM.restore();

    ctxM.globalAlpha = 1;

    animFrame = requestAnimationFrame(drawFrame);
  }

  // ── Start camera ──
  async function startCamera() {
    if (stream) {
      stream.getTracks().forEach(t => t.stop());
      stream = null;
    }
    running = false;
    cancelAnimationFrame(animFrame);

    const constraints = {
      video: {
        facingMode: facingMode,
        width:  { ideal: 1280 },
        height: { ideal: 720 }
      },
      audio: false
    };

    try {
      stream = await navigator.mediaDevices.getUserMedia(constraints);
      video.srcObject = stream;
      await video.play();

      resizeCanvases();
      startScr.classList.add('hidden');
      errorMsg.classList.remove('show');
      liveDot.classList.add('active');
      liveText.textContent = 'EN VIVO';
      running = true;
      animFrame = requestAnimationFrame(drawFrame);

    } catch (err) {
      errorMsg.classList.add('show');
      startScr.classList.add('hidden');
      errorText.textContent = err.name === 'NotAllowedError'
        ? 'Permiso de cámara denegado.'
        : err.name === 'NotFoundError'
        ? 'No se encontró ninguna cámara.'
        : 'Error al acceder a la cámara: ' + err.message;
      liveDot.classList.remove('active');
      liveText.textContent = 'ERROR';
    }
  }

  btnStart.addEventListener('click', startCamera);

  btnFlip.addEventListener('click', async () => {
    if (!running) return;
    facingMode = facingMode === 'user' ? 'environment' : 'user';
    await startCamera();
  });

  // ── Check getUserMedia support ──
  if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
    errorMsg.classList.add('show');
    startScr.classList.add('hidden');
    errorText.textContent = 'Tu navegador no soporta acceso a cámara.';
  }

})();
</script>

