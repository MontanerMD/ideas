<style>
/* ── RESET & ROOT ── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --sage:        #7a9e7e;
  --sage-light:  #b8d4bb;
  --sage-dark:   #4a7050;
  --cream:       #faf6f0;
  --warm:        #f5ede0;
  --terra:       #c87941;
  --terra-light: #e8a96a;
  --charcoal:    #2d2d2d;
  --muted:       #888888;
  --white:       #ffffff;
  --border:      #e8e0d5;
  --shadow:      0 4px 24px rgba(74,112,80,.10);
  --shadow-lg:   0 8px 40px rgba(74,112,80,.18);
  --r:           20px;
  --r-sm:        12px;
  --font-head:   'Playfair Display', Georgia, 'Times New Roman', serif;
  --font-body:   'DM Sans', 'Segoe UI', system-ui, sans-serif;
}
html { scroll-behavior: smooth; }
body {
  font-family: var(--font-body);
  background: var(--cream);
  color: var(--charcoal);
  min-height: 100vh;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}
button { cursor: pointer; font-family: var(--font-body); border: none; background: none; }

/* ── HEADER ── */
header {
background: linear-gradient(135deg, var(–sage-dark) 0%, var(–sage) 65%, var(–sage-light) 100%);
color: var(–white);
padding: 20px 18px;
position: sticky; top: 0; z-index: 200;
box-shadow: 0 2px 20px rgba(74,112,80,.28);
}
.hdr {
max-width: 720px; margin: 0 auto;
display: flex; align-items: center; gap: 14px;
}
.hdr-logo {
width: 50px; height: 50px; border-radius: 50%;
background: rgba(255,255,255,.18);
display: flex; align-items: center; justify-content: center;
font-size: 1.5rem; flex-shrink: 0;
}
.hdr-title { font-family: var(–font-head); font-size: 1.35rem; font-weight: 900; line-height: 1.15; }
.hdr-sub   { font-size: .78rem; opacity: .8; margin-top: 2px; }

/* ── TABS ── */
.tab-bar {
max-width: 720px; margin: 0 auto;
display: flex;
background: var(–white);
border-bottom: 2px solid var(–border);
position: sticky; top: 83px; z-index: 190;
box-shadow: 0 2px 8px rgba(0,0,0,.05);
}
.tab-btn {
flex: 1; padding: 13px 6px;
font-size: .83rem; font-weight: 600;
color: var(–muted);
border-bottom: 3px solid transparent;
transition: color .2s, border-color .2s, background .2s;
display: flex; align-items: center; justify-content: center; gap: 5px;
}
.tab-btn.active  { color: var(–sage-dark); border-bottom-color: var(–sage-dark); }
.tab-btn:hover:not(.active) { color: var(–sage); background: var(–warm); }

/* ── PAGE WRAPPER ── */
.page { max-width: 720px; margin: 0 auto; padding: 18px 14px 72px; }
.tab-pane { display: none; }
.tab-pane.active { display: block; }

/* ── TODAY HERO ── */
.hero {
background: linear-gradient(135deg, var(–sage-dark), var(–sage));
border-radius: var(–r); padding: 20px 20px 16px;
color: var(–white); margin-bottom: 18px;
display: flex; align-items: center; justify-content: space-between; gap: 12px;
}
.hero-day  { font-family: var(–font-head); font-size: 1.45rem; font-weight: 900; }
.hero-date { font-size: .8rem; opacity: .8; margin-top: 3px; }
.hero-badge {
background: rgba(255,255,255,.2); border-radius: 10px;
padding: 7px 12px; font-size: .74rem; font-weight: 700;
text-transform: uppercase; letter-spacing: .5px; flex-shrink: 0; text-align: center;
}

/* ── DAY NAV ── */
.day-nav {
display: flex; gap: 7px; margin-bottom: 18px;
overflow-x: auto; padding-bottom: 4px;
-ms-overflow-style: none; scrollbar-width: none;
}
.day-nav::-webkit-scrollbar { display: none; }
.day-pill {
flex-shrink: 0; padding: 8px 15px; border-radius: 50px;
font-size: .8rem; font-weight: 600;
background: var(–white); color: var(–muted);
border: 2px solid var(–border);
transition: all .2s;
}
.day-pill.active   { background: var(–sage-dark); color: var(–white); border-color: var(–sage-dark); }
.day-pill:hover:not(.active) { border-color: var(–sage); color: var(–sage-dark); }

/* ── MEAL CARDS ── */
.meals { display: flex; flex-direction: column; gap: 12px; }

.card {
background: var(–white); border-radius: var(–r-sm);
box-shadow: var(–shadow);
overflow: hidden;
transition: box-shadow .22s, transform .22s;
}
.card:hover { box-shadow: var(–shadow-lg); transform: translateY(-2px); }

.card-head {
display: flex; align-items: center; gap: 12px;
padding: 14px 16px; cursor: pointer; user-select: none;
-webkit-tap-highlight-color: transparent;
}
.card-ico {
width: 42px; height: 42px; border-radius: 11px;
display: flex; align-items: center; justify-content: center;
font-size: 1.3rem; flex-shrink: 0;
}
.ci1 { background: #e8f5e9; } .ci2 { background: #fff3e0; }
.ci3 { background: #e3f2fd; } .ci4 { background: #fce4ec; } .ci5 { background: #f3e5f5; }

.card-meta { flex: 1; min-width: 0; }
.card-ingesta { font-size: .68rem; font-weight: 700; color: var(–sage); text-transform: uppercase; letter-spacing: .7px; }
.card-name    { font-size: .92rem; font-weight: 600; margin-top: 2px; line-height: 1.3; }

.card-arrow { font-size: 1.1rem; color: var(–muted); transition: transform .22s; flex-shrink: 0; }
.card.open .card-arrow { transform: rotate(180deg); }

.card-body {
display: none; padding: 4px 16px 16px;
border-top: 1px solid #f0ece6;
animation: fadeDown .2s ease;
}
.card.open .card-body { display: block; }
@keyframes fadeDown { from { opacity: 0; transform: translateY(-6px); } to { opacity: 1; transform: none; } }

/* simple detail text */
.detail-text { font-size: .86rem; color: #555; line-height: 1.6; margin-top: 10px; }
.pill-row { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 10px; }
.pill {
display: inline-flex; align-items: center; gap: 4px;
background: #e8f5ea; color: var(–sage-dark);
border-radius: 20px; padding: 4px 11px;
font-size: .74rem; font-weight: 600;
}

/* ── BREAKFAST CHOOSER ── */
.bf-hint { font-size: .8rem; color: var(–muted); padding: 10px 0 6px; }
.bf-options { display: flex; flex-direction: column; gap: 9px; margin-top: 4px; }

.bf-opt {
border: 2px solid var(–border); border-radius: var(–r-sm);
padding: 12px 14px; cursor: pointer; transition: all .2s;
background: var(–warm); -webkit-tap-highlight-color: transparent;
}
.bf-opt:hover   { border-color: var(–sage); background: #f0f8f1; }
.bf-opt.sel     { border-color: var(–sage-dark); background: #e8f5ea; }
.bf-opt-title   { font-weight: 600; font-size: .88rem; }
.bf-opt-sub     { font-size: .76rem; color: var(–muted); margin-top: 3px; }

.bf-recipe { display: none; margin-top: 12px; background: var(–white); border-radius: 10px; padding: 14px; border: 1px solid var(–border); }
.bf-opt.sel .bf-recipe { display: block; }

.recipe-section-title {
font-size: .72rem; font-weight: 800; text-transform: uppercase;
letter-spacing: .8px; margin-bottom: 8px;
}
.rt-ing  { color: var(–terra); }
.rt-step { color: var(–sage-dark); }

.ing-tags { display: flex; flex-wrap: wrap; gap: 5px; margin-bottom: 14px; }
.ing-tag {
background: #fff7f0; border: 1px solid #f0d8c0;
color: var(–terra); border-radius: 20px;
padding: 4px 10px; font-size: .75rem; font-weight: 500;
}
.step-list { list-style: none; }
.step-list li { display: flex; gap: 9px; margin-bottom: 8px; font-size: .82rem; color: #555; line-height: 1.45; }
.step-n {
flex-shrink: 0; width: 22px; height: 22px;
background: var(–sage-light); color: var(–sage-dark);
border-radius: 50%; font-size: .68rem; font-weight: 700;
display: flex; align-items: center; justify-content: center; margin-top: 1px;
}

/* ── FREE DAY ── */
.free-box {
background: linear-gradient(135deg, #fff8f0, #ffeedd);
border: 2px dashed var(–terra-light);
border-radius: var(–r-sm); padding: 24px 20px; text-align: center; margin-top: 8px;
}
.free-box .big  { font-size: 2.4rem; }
.free-box h3    { font-family: var(–font-head); font-size: 1.15rem; color: var(–terra); margin-top: 8px; }
.free-box p     { color: var(–muted); font-size: .84rem; margin-top: 5px; }

/* ── TIP BOX ── */
.tip {
background: #e8f5ea; border-left: 4px solid var(–sage);
border-radius: 8px; padding: 11px 13px;
font-size: .8rem; color: var(–sage-dark); line-height: 1.5; margin-top: 12px;
}

/* ── BADGE ── */
.badge-libre {
background: var(–terra); color: var(–white);
padding: 2px 8px; border-radius: 20px; font-size: .68rem; font-weight: 700; margin-left: 6px;
}

/* ── PLANNING TAB ── */
.sec-title {
font-family: var(–font-head); font-size: 1.1rem; color: var(–sage-dark);
margin: 24px 0 12px; display: flex; align-items: center; gap: 8px;
}
.sec-title:first-child { margin-top: 0; }

.info-card {
background: var(–white); border-radius: var(–r-sm);
box-shadow: var(–shadow); padding: 14px 16px; margin-bottom: 10px;
font-size: .86rem; color: #555; line-height: 1.6;
}
.info-card strong { color: var(–charcoal); }

/* week grid */
.week-scroll { overflow-x: auto; -webkit-overflow-scrolling: touch; padding-bottom: 4px; }
.week-grid   { display: grid; grid-template-columns: repeat(7, minmax(96px, 1fr)); gap: 5px; min-width: 640px; }
.week-col    {}
.week-dh     {
background: var(–sage-dark); color: var(–white);
text-align: center; padding: 8px 4px;
border-radius: 10px 10px 0 0;
font-size: .68rem; font-weight: 700; letter-spacing: .5px; text-transform: uppercase;
}
.week-cell   {
background: var(–white); border: 1px solid var(–border);
padding: 8px 6px; font-size: .71rem; color: #555; min-height: 58px; line-height: 1.4;
}
.week-cell:last-child { border-radius: 0 0 10px 10px; }
.week-lbl    { font-size: .62rem; font-weight: 700; color: var(–sage); text-transform: uppercase; letter-spacing: .5px; margin-bottom: 3px; }
.week-libre  { background: #fff8f0; color: var(–terra); font-weight: 600; text-align: center; display: flex; align-items: center; justify-content: center; flex-direction: column; gap: 4px; }

/* dinner grid */
.dinner-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
.dinner-card { background: var(–white); border-radius: var(–r-sm); box-shadow: var(–shadow); padding: 12px 14px; }
.dinner-day  { font-size: .68rem; font-weight: 700; color: var(–sage); text-transform: uppercase; letter-spacing: .5px; margin-bottom: 5px; }
.dinner-card p { font-size: .82rem; color: #555; line-height: 1.5; }
.full-col    { grid-column: 1 / -1; }

/* ── PORTIONS TAB ── */
.portions-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
.por-card {
background: var(–white); border-radius: var(–r-sm);
box-shadow: var(–shadow); padding: 14px 15px;
display: flex; align-items: center; gap: 12px;
}
.por-ico   { font-size: 1.65rem; flex-shrink: 0; }
.por-type  { font-size: .72rem; color: var(–muted); font-weight: 500; }
.por-amt   { font-size: 1rem; font-weight: 700; margin-top: 1px; }

.saved-bf  {
background: var(–white); border-radius: var(–r-sm);
box-shadow: var(–shadow); padding: 14px 16px;
font-size: .86rem; color: var(–muted); line-height: 1.6;
}

/* ── RESPONSIVE ── */
@media (max-width: 480px) {
.hdr-title { font-size: 1.15rem; }
.tab-btn   { font-size: .77rem; padding: 12px 4px; }
.tab-bar   { top: 77px; }
.dinner-grid { grid-template-columns: 1fr; }
.portions-grid { grid-template-columns: 1fr 1fr; }
}
</style>

</head>
