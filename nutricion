      ing:['Pan blanco','Rúcula','Requesón 0%','Mermelada de tomate y albahaca','Jamón serrano','Berenjena','Nueces'],
      steps:[
        'Lava y trocea la berenjena en rodajas.',
        'Haz la berenjena a la plancha con un chorrito de aceite.',
        'Tuesta el pan en tostadora o sartén.',
        'Unta el requesón en la tostada.',
        'Añade la berenjena, jamón serrano y mermelada de tomate.',
        'Termina con las nueces y la rúcula. ¡Buen provecho!'
      ]
    }
  ];

  var MEALS = {
    0: { libre3: true,
         cena: { emoji:'🍜', name:'Ramen', detail:'Domingo libre: Ramen a tu gusto. ¡Disfrútalo!', libre:false } },
    1: { comida: { emoji:'🥢', name:'Arroz integral + Mix verduras teriyaki + Huevo roto',
                   detail:'Arroz integral (50/25/15g) cocinado con pastilla de caldo, ajo y pimentón, más sofrito de cebolla y tomate. Acompañado de mix de verduras (calabacín, zanahoria, pimiento, bimi, champiñones…) con salsa teriyaki y huevo roto 🥚.' },
         cena:   { emoji:'🎃', name:'Crema de calabaza y zanahoria (sin patata)',
                   detail:'Crema de calabaza y zanahoria sin patata. Puedes condimentar con cúrcuma, jengibre y aceite de oliva virgen extra.' } },
    2: { comida: { emoji:'🍗', name:'Pechuga de pollo o pavo (especiada) + verdura anterior',
                   detail:'Pechuga de pollo o pavo especiada, acompañada de la verdura sobrante del lunes en menor cantidad. Base de arroz integral (50/25/15g).' },
         cena:   { emoji:'🍔', name:'Hamburguesa de ternera + Crema de calabaza y zanahoria',
                   detail:'Hamburguesa de ternera al plato (120-160g) acompañada de crema de calabaza y zanahoria.' } },
    3: { comida: { emoji:'🐟', name:'Merluza salsa verde + Espárragos + Verduras',
                   detail:'Merluza en salsa verde con espárragos y verduras del primer día si te quedan. Base de pasta de lentejas (80/50/30g).' },
         cena:   { emoji:'🍕', name:'Pizza Libre 🎉', detail:'¡Cena libre! Disfruta de una pizza a tu elección.', libre:true } },
    4: { comida: { emoji:'🥗', name:'Pesto + Huevo frito + Atún',
                   detail:'Pasta de lentejas (80/50/30g) con pesto, huevo frito y atún. Rico en proteínas y grasas saludables.' },
         cena:   { emoji:'🐟', name:'Bacalao a la plancha + Puré de patata + Espárragos',
                   detail:'Bacalao a la plancha (140-160g) con puré de patata (permitido hoy) y espárragos.' } },
    5: { comida: { emoji:'🍝', name:'Boloñesa',
                   detail:'Pasta de lentejas (80/50/30g) con salsa boloñesa. Puedes usar carne picada de ternera (120-160g).' },
         cena:   { emoji:'🥩', name:'Carne / Pescado / Huevo + Verdura (sin postre)',
                   detail:'Elige entre carne, pescado o huevo con verdura al gusto. Sin postre esta noche.' } },
    6: { comida: { emoji:'🍱', name:'Pollo troceado especiado + Verduritas',
                   detail:'Pollo troceado y especiado con verduritas (suele venir en bandejas). Base de pasta de lentejas (80/50/30g).' },
         cena:   { emoji:'🍲', name:'Hervido valenciano',
                   detail:'Hervido valenciano: verduras de temporada, patata, judía verde, zanahoria, aceite de oliva y sal.' } }
  };

  /* ─── STATE ─── */
  var selDay = new Date().getDay();
  var selBf  = localStorage.getItem('noemi_bf') || '';

  /* ─── TABS ─── */
  document.querySelectorAll('.tab-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var tab = btn.dataset.tab;
      document.querySelectorAll('.tab-btn').forEach(function(b){ b.classList.remove('active'); });
      document.querySelectorAll('.tab-pane').forEach(function(p){ p.classList.remove('active'); });
      btn.classList.add('active');
      document.getElementById('pane-' + tab).classList.add('active');
      if (tab === 'porciones') renderSavedBf();
    });
  });

  /* ─── HERO ─── */
  function renderHero() {
    var today = new Date().getDay();
    var isToday = selDay === today;
    document.getElementById('heroDay').textContent  = (isToday ? 'Hoy · ' : '') + DAYS_ES[selDay];
    document.getElementById('heroBadge').textContent = isToday ? '📍 HOY' : DAYS_SH[selDay];
    var d = new Date();
    d.setDate(d.getDate() + (selDay - today));
    document.getElementById('heroDate').textContent = d.toLocaleDateString('es-ES', {weekday:'long', year:'numeric', month:'long', day:'numeric'});
  }

  /* ─── DAY NAV ─── */
  function renderDayNav() {
    var nav = document.getElementById('dayNav');
    nav.innerHTML = '';
    var today = new Date().getDay();
    DAYS_ES.forEach(function(d, i) {
      var btn = document.createElement('button');
      btn.className = 'day-pill' + (i === selDay ? ' active' : '');
      btn.textContent = (i === today ? '📍 ' : '') + DAYS_SH[i];
      btn.addEventListener('click', function() {
        selDay = i; renderDayNav(); renderHero(); renderMeals();
      });
      nav.appendChild(btn);
    });
  }

  /* ─── CARD TOGGLE ─── */
  function toggleCard(card) {
    card.classList.toggle('open');
  }

  /* ─── BREAKFAST CARD ─── */
  function makeBreakfastCard() {
    var card = document.createElement('div');
    card.className = 'card';

    var optionsHtml = BREAKFASTS.map(function(b) {
      var isSel = selBf === b.id;
      var ingHtml = b.ing.map(function(i){ return '<span class="ing-tag">🥄 ' + i + '</span>'; }).join('');
      var stepsHtml = b.steps.map(function(s, idx){
        return '<li><span class="step-n">' + (idx+1) + '</span><span>' + s + '</span></li>';
      }).join('');
      return '<div class="bf-opt' + (isSel ? ' sel' : '') + '" data-bid="' + b.id + '">' +
        '<div class="bf-opt-title">' + b.emoji + ' ' + b.title + '</div>' +
        '<div class="bf-opt-sub">' + b.sub + '</div>' +
        '<div class="bf-recipe">' +
          '<div class="recipe-section-title rt-ing">🧂 Ingredientes</div>' +
          '<div class="ing-tags" style="margin-bottom:12px">' + ingHtml + '</div>' +
          '<div class="recipe-section-title rt-step">🍳 Paso a paso</div>' +
          '<ul class="step-list">' + stepsHtml + '</ul>' +
        '</div></div>';
    }).join('');

    card.innerHTML =
      '<div class="card-head">' +
        '<div class="card-ico ci2">🥤</div>' +
        '<div class="card-meta">' +
          '<div class="card-ingesta">Ingesta nº2</div>' +
          '<div class="card-name">Desayuno — Elige tu opción</div>' +
        '</div>' +
        '<div class="card-arrow">⌄</div>' +
      '</div>' +
      '<div class="card-body">' +
        '<div class="bf-hint">Toca una opción para ver la receta 👇</div>' +
        '<div class="bf-options">' + optionsHtml + '</div>' +
        '<div class="tip">💡 Rota entre las opciones cada 2 días según indica tu plan.</div>' +
      '</div>';

    card.querySelector('.card-head').addEventListener('click', function(){ toggleCard(card); });

    card.querySelectorAll('.bf-opt').forEach(function(opt) {
      opt.addEventListener('click', function(e) {
        e.stopPropagation();
        var bid = opt.dataset.bid;
        selBf = (selBf === bid) ? '' : bid;
        localStorage.setItem('noemi_bf', selBf);
        renderMeals();
        // keep breakfast card open after re-render
        setTimeout(function(){
          var cards = document.querySelectorAll('#mealsList .card');
          if (cards[1]) cards[1].classList.add('open');
        }, 0);
      });
    });

    return card;
  }

  /* ─── SIMPLE CARD ─── */
  function makeSimpleCard(ciClass, emoji, ingesta, name, detail) {
    var card = document.createElement('div');
    card.className = 'card';
    card.innerHTML =
      '<div class="card-head">' +
        '<div class="card-ico ' + ciClass + '">' + emoji + '</div>' +
        '<div class="card-meta">' +
          '<div class="card-ingesta">' + ingesta + '</div>' +
          '<div class="card-name">' + name + '</div>' +
        '</div>' +
        '<div class="card-arrow">⌄</div>' +
      '</div>' +
      '<div class="card-body">' +
        '<div class="detail-text">' + detail + '</div>' +
        '<div class="pill-row">' +
          '<span class="pill">🍗 Carne blanca 150-180g</span>' +
          '<span class="pill">🥩 Carne roja 120-160g</span>' +
          '<span class="pill">🐟 Pescado 140-160g</span>' +
        '</div>' +
      '</div>';
    card.querySelector('.card-head').addEventListener('click', function(){ toggleCard(card); });
    return card;
  }

  /* ─── MEALS RENDER ─── */
  function renderMeals() {
    renderHero();
    var list = document.getElementById('mealsList');
    list.innerHTML = '';
    var dayData = MEALS[selDay] || {};

    /* Ingesta 1 */
    var c1 = document.createElement('div');
    c1.className = 'card';
    c1.innerHTML =
      '<div class="card-head">' +
        '<div class="card-ico ci1">☕</div>' +
        '<div class="card-meta">' +
          '<div class="card-ingesta">Ingesta nº1</div>' +
          '<div class="card-name">Matcha &amp; Entreno</div>' +
        '</div>' +
        '<div class="card-arrow">⌄</div>' +
      '</div>' +
      '<div class="card-body">' +
        '<div class="detail-text">Comienza el día con matcha. Esta ingesta va ligada al entrenamiento, ya sea antes o durante.</div>' +
      '</div>';
    c1.querySelector('.card-head').addEventListener('click', function(){ toggleCard(c1); });
    list.appendChild(c1);

    /* Ingesta 2 */
    list.appendChild(makeBreakfastCard());

    /* Ingesta 3 */
    if (dayData.libre3) {
      var cLib = document.createElement('div');
      cLib.className = 'card';
      cLib.innerHTML =
        '<div class="card-head">' +
          '<div class="card-ico ci3">🎉</div>' +
          '<div class="card-meta">' +
            '<div class="card-ingesta">Ingesta nº3</div>' +
            '<div class="card-name">Día Libre <span class="badge-libre">LIBRE</span></div>' +
          '</div>' +
        '</div>' +
        '<div class="card-body" style="display:block">' +
          '<div class="free-box">' +
            '<div class="big">🎉</div>' +
            '<h3>¡Domingo libre!</h3>' +
            '<p>Disfruta de la comida que más te apetezca hoy. ¡Te lo mereces!</p>' +
          '</div>' +
        '</div>';
      list.appendChild(cLib);
    } else if (dayData.comida) {
      var d = dayData.comida;
      var libreTag = d.libre ? '<span class="badge-libre">LIBRE</span>' : '';
      var c3 = document.createElement('div');
      c3.className = 'card';
      c3.innerHTML =
        '<div class="card-head">' +
          '<div class="card-ico ci3">' + d.emoji + '</div>' +
          '<div class="card-meta">' +
            '<div class="card-ingesta">Ingesta nº3 · Comida</div>' +
            '<div class="card-name">' + d.name + libreTag + '</div>' +
          '</div>' +
          '<div class="card-arrow">⌄</div>' +
        '</div>' +
        '<div class="card-body">' +
          '<div class="detail-text">' + d.detail + '</div>' +
        '</div>';
      c3.querySelector('.card-head').addEventListener('click', function(){ toggleCard(c3); });
      list.appendChild(c3);
    }

    /* Ingesta 4 */
    var c4 = document.createElement('div');
    c4.className = 'card';
    c4.innerHTML =
      '<div class="card-head">' +
        '<div class="card-ico ci4">🍫</div>' +
        '<div class="card-meta">' +
          '<div class="card-ingesta">Ingesta nº4 · Merienda</div>' +
          '<div class="card-name">Mousse de chocolate o Tostadas de calabacín</div>' +
        '</div>' +
        '<div class="card-arrow">⌄</div>' +
      '</div>' +
      '<div class="card-body">' +
        '<div class="detail-text">🍫 <strong>Mousse de chocolate</strong> (ver enlace en tu plan)<br>🥒 <strong>Tostadas de calabacín</strong> (ver enlace en tu plan)</div>' +
      '</div>';
    c4.querySelector('.card-head').addEventListener('click', function(){ toggleCard(c4); });
    list.appendChild(c4);

    /* Ingesta 5 */
    if (dayData.cena) {
      var c = dayData.cena;
      var lt = c.libre ? '<span class="badge-libre">LIBRE</span>' : '';
      var c5 = document.createElement('div');
      c5.className = 'card';
      c5.innerHTML =
        '<div class="card-head">' +
          '<div class="card-ico ci5">' + c.emoji + '</div>' +
          '<div class="card-meta">' +
            '<div class="card-ingesta">Ingesta nº5 · Cena</div>' +
            '<div class="card-name">' + c.name + lt + '</div>' +
          '</div>' +
          '<div class="card-arrow">⌄</div>' +
        '</div>' +
        '<div class="card-body">' +
          '<div class="detail-text">' + c.detail + '</div>' +
        '</div>';
      c5.querySelector('.card-head').addEventListener('click', function(){ toggleCard(c5); });
      list.appendChild(c5);
    }
  }

  /* ─── SAVED BREAKFAST ─── */
  function renderSavedBf() {
    var box = document.getElementById('savedBf');
    if (!selBf) {
      box.innerHTML = 'Aún no has elegido ningún desayuno. Ve a la pestaña Agenda y selecciona el que más te apetezca 👆';
      return;
    }
    var b = BREAKFASTS.filter(function(x){ return x.id === selBf; })[0];
    if (!b) return;
    box.innerHTML =
      '<strong>' + b.emoji + ' ' + b.title + '</strong><br>' +
      '<span style="color:var(--sage-dark);font-size:.8rem">' + b.sub + '</span><br><br>' +
      '<span style="font-size:.78rem;color:var(--muted)">Ingredientes: ' + b.ing.join(' · ') + '</span>';
  }

  /* ─── INIT ─── */
  renderDayNav();
  renderHero();
  renderMeals();

})();
</script>

</body>
</html>